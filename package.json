{
  "name": "media-growth-cockpit",
  "version": "0.6.1",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "node --test server/tests/*.test.mjs",
    "probe:agents": "node --env-file-if-exists=.env scripts/probe-local-agents.mjs",
    "verify:v05:agent": "node --env-file-if-exists=.env scripts/verify-v05-real-agent.mjs",
    "verify:v06:conversation": "node --env-file-if-exists=.env scripts/verify-v06-real-conversation.mjs",
    "verify:v061:antigravity": "node --env-file-if-exists=.env scripts/verify-v061-antigravity.mjs",
    "index": "node --env-file-if-exists=.env scripts/build-vault-index.mjs",
    "validate:data": "node --env-file-if-exists=.env scripts/validate-data.mjs",
    "setup:vault": "node --env-file-if-exists=.env scripts/setup-vault.mjs",
    "test:indexer": "node --test scripts/tests/*.test.mjs",
    "predev": "npm run index",
    "prebuild": "npm run index && npm run validate:data"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.59.0",
    "@agentclientprotocol/codex-acp": "^1.1.2",
    "@agentclientprotocol/sdk": "^1.2.1",
    "better-sqlite3": "^12.11.1",
    "phosphor-react": "^1.4.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vite": "^6.4.3",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}
